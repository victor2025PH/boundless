*.pem
id_ed25519*
.env
.env.*
prod.env.local
**/creds.json
**/服务器密码.txt
llm_backends.json
config.yaml

# ---- python ----
__pycache__/
*.pyc
.venv/
.venv_*/

# ---- node / next ----
node_modules/
.next/
build/
dist/

# ---- runtime / logs / data ----
logs/
data/
tmp/
temp/
