{
  "_note": "无界科技 BOUNDLESS · 设计令牌单一真相（Single Source of Truth）。本文件是唯一手工维护的数据源：tailwind-preset.cjs 在运行时 require 本文件机械派生；brand.css 手工同步后按 BRAND_TOKENS.md 的流程核对。骨架沿用 TG智控王 design-tokens.ts 的层级（spacing/radius/shadow/motion/zIndex/breakpoints），品牌色与字体以无界母品牌 brand-assets 为准。本层零反向依赖：不 import 任何产品/引擎代码。",
  "_conventions": "以 _ 开头的键（_note/_sources 等）均为注释，消费方必须忽略；颜色一律小写 hex；spacing 键的小数点在 CSS 变量名中写作 -（0.5 → --bl-space-0-5）。",
  "_sources": {
    "skeleton": "TG智控王 tgkz2026/src/design-system/design-tokens.ts（结构骨架：间距/圆角/阴影/动效/层级/断点/字号阶）",
    "brand": "boundless/brand-assets/README.md + build_brand_assets.py（∞ 渐变、深空底、墨色、三系光环、字体）",
    "categories": "boundless/website/lib/brand.ts（三系 CATEGORIES 的 accent 语义：growth=cyan / studio=violet / lingo=amber）"
  },
  "version": "1.0.0",

  "brand": {
    "_note": "母品牌视觉常量，与 brand-assets 生成脚本同源。",
    "palette": {
      "_note": "∞ 主标渐变的 7 个具名色标（从左到右）。",
      "cyan": "#00b0f0",
      "blue": "#1e6bf0",
      "violet": "#7a3bf5",
      "magenta": "#d030f0",
      "pink": "#f0509a",
      "orange": "#f07800",
      "amber": "#f0a010"
    },
    "gradient": {
      "_note": "∞ 主标渐变。stops 顺序即渐变顺序；圆形光环（头像 ring）首尾补一个 cyan 闭环（ringClose）。css 为按 7 stop 均分拼好的便捷字符串，brand.css 与 tailwind-preset 原样引用。",
      "stops": ["#00b0f0", "#1e6bf0", "#7a3bf5", "#d030f0", "#f0509a", "#f07800", "#f0a010"],
      "ringClose": "#00b0f0",
      "css": "linear-gradient(90deg, #00b0f0 0%, #1e6bf0 16.667%, #7a3bf5 33.333%, #d030f0 50%, #f0509a 66.667%, #f07800 83.333%, #f0a010 100%)"
    },
    "darkSpace": {
      "_note": "深空底：唯一合法的深色界面底色（冲突消解：替代智控王的 slate 暗底）。",
      "top": "#1a1d3a",
      "bottom": "#05060f",
      "css": "linear-gradient(180deg, #1a1d3a 0%, #05060f 100%)"
    },
    "ink": {
      "_note": "墨色与深空中性阶。text = 浅底正文墨色；950/900 页面底、800 卡片面、700 分隔/描边（数值为深空渐变端点的内插，与官网现网 ink 阶一致）。",
      "text": "#0b1020",
      "700": "#1a1d3a",
      "800": "#11132a",
      "900": "#0a0c1b",
      "950": "#05060f"
    }
  },

  "categoryAccents": {
    "_note": "三系光环色，与 brand-assets 头像光环、website/lib/brand.ts 的 accent 字段同源（growth=cyan 智连蓝 / studio=violet 幻境紫 / lingo=amber 通达橙）。scale 由 accent(=500) 的 HSL 按统一亮度阶梯 96.5/93/86/76/64.5/(原值)/45/38/31/25 生成。ring 为资源号光环渐变（圆环使用 from→to→from 闭环）。",
    "growth": {
      "_note": "智连系（社交增长）：智拓 ReachX · 智聊 ChatX；TG-AI智控王 亦属本系，其 primary 对齐智连蓝。",
      "zh": "智连",
      "en": "Growth",
      "accent": "#1e8cf2",
      "ring": {
        "from": "#0070f0",
        "to": "#00c2ff",
        "css": "linear-gradient(135deg, #0070f0 0%, #00c2ff 100%)"
      },
      "scale": {
        "50": "#eef6fe",
        "100": "#ddeefd",
        "200": "#bcdcfb",
        "300": "#8bc4f8",
        "400": "#54a7f5",
        "500": "#1e8cf2",
        "600": "#0d76d9",
        "700": "#0b64b7",
        "800": "#095295",
        "900": "#074278"
      }
    },
    "studio": {
      "_note": "幻境系（数字分身）：幻颜 FaceX · 幻声 VoiceX · 幻影 LiveX。",
      "zh": "幻境",
      "en": "Studio",
      "accent": "#c43bf0",
      "ring": {
        "from": "#b62bf5",
        "to": "#f050c8",
        "css": "linear-gradient(135deg, #b62bf5 0%, #f050c8 100%)"
      },
      "scale": {
        "50": "#faeefe",
        "100": "#f5defc",
        "200": "#ebbdfa",
        "300": "#dd8df6",
        "400": "#cc57f2",
        "500": "#c43bf0",
        "600": "#a510d5",
        "700": "#8c0eb4",
        "800": "#720b93",
        "900": "#5c0976"
      }
    },
    "lingo": {
      "_note": "通达系（跨语沟通）：通译 LingoX · 通传 VoxX。accent 与品牌渐变 orange 色标同值。",
      "zh": "通达",
      "en": "Lingo",
      "accent": "#f07800",
      "ring": {
        "from": "#f06a00",
        "to": "#ffb020",
        "css": "linear-gradient(135deg, #f06a00 0%, #ffb020 100%)"
      },
      "scale": {
        "50": "#fff6ed",
        "100": "#ffeddb",
        "200": "#ffdbb8",
        "300": "#ffc285",
        "400": "#ffa44a",
        "500": "#f07800",
        "600": "#e67300",
        "700": "#c26100",
        "800": "#9e4f00",
        "900": "#804000"
      }
    }
  },

  "semantic": {
    "_note": "语义色，沿用智控王原值（Tailwind 标准色板：green/amber/red/sky）。",
    "success": {
      "50": "#f0fdf4",
      "100": "#dcfce7",
      "200": "#bbf7d0",
      "300": "#86efac",
      "400": "#4ade80",
      "500": "#22c55e",
      "600": "#16a34a",
      "700": "#15803d",
      "800": "#166534",
      "900": "#14532d"
    },
    "warning": {
      "50": "#fffbeb",
      "100": "#fef3c7",
      "200": "#fde68a",
      "300": "#fcd34d",
      "400": "#fbbf24",
      "500": "#f59e0b",
      "600": "#d97706",
      "700": "#b45309",
      "800": "#92400e",
      "900": "#78350f"
    },
    "error": {
      "50": "#fef2f2",
      "100": "#fee2e2",
      "200": "#fecaca",
      "300": "#fca5a5",
      "400": "#f87171",
      "500": "#ef4444",
      "600": "#dc2626",
      "700": "#b91c1c",
      "800": "#991b1b",
      "900": "#7f1d1d"
    },
    "info": {
      "50": "#f0f9ff",
      "100": "#e0f2fe",
      "200": "#bae6fd",
      "300": "#7dd3fc",
      "400": "#38bdf8",
      "500": "#0ea5e9",
      "600": "#0284c7",
      "700": "#0369a1",
      "800": "#075985",
      "900": "#0c4a6e"
    }
  },

  "gray": {
    "_note": "中性灰（正文辅助色/边框/浅色面板），沿用智控王。",
    "50": "#f9fafb",
    "100": "#f3f4f6",
    "200": "#e5e7eb",
    "300": "#d1d5db",
    "400": "#9ca3af",
    "500": "#6b7280",
    "600": "#4b5563",
    "700": "#374151",
    "800": "#1f2937",
    "900": "#111827",
    "950": "#030712"
  },

  "slate": {
    "_note": "冷灰备用阶，沿用智控王。注意：深色界面底色一律改用 brand.ink 深空阶，slate-800/900/950 不再作为暗底（冲突消解）。",
    "50": "#f8fafc",
    "100": "#f1f5f9",
    "200": "#e2e8f0",
    "300": "#cbd5e1",
    "400": "#94a3b8",
    "500": "#64748b",
    "600": "#475569",
    "700": "#334155",
    "800": "#1e293b",
    "900": "#0f172a",
    "950": "#020617"
  },

  "spacing": {
    "_note": "4px 基数间距阶，沿用智控王。",
    "0": "0",
    "px": "1px",
    "0.5": "0.125rem",
    "1": "0.25rem",
    "1.5": "0.375rem",
    "2": "0.5rem",
    "2.5": "0.625rem",
    "3": "0.75rem",
    "3.5": "0.875rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "7": "1.75rem",
    "8": "2rem",
    "9": "2.25rem",
    "10": "2.5rem",
    "11": "2.75rem",
    "12": "3rem",
    "14": "3.5rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem",
    "28": "7rem",
    "32": "8rem"
  },

  "radius": {
    "_note": "圆角阶，沿用智控王；DEFAULT = 4px。",
    "none": "0",
    "sm": "0.125rem",
    "DEFAULT": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "3xl": "1.5rem",
    "full": "9999px"
  },

  "shadow": {
    "_note": "阴影阶，沿用智控王；primary 投影色已随主色改为智连蓝 rgba(30,140,242) = #1e8cf2（原 #3b82f6）。",
    "none": "none",
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "DEFAULT": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
    "2xl": "0 25px 50px -12px rgb(0 0 0 / 0.25)",
    "inner": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)",
    "primary": "0 4px 14px 0 rgba(30, 140, 242, 0.25)",
    "success": "0 4px 14px 0 rgba(34, 197, 94, 0.25)",
    "error": "0 4px 14px 0 rgba(239, 68, 68, 0.25)"
  },

  "typography": {
    "fontFamily": {
      "_note": "冲突消解：英文 Inter→Montserrat、中文 Noto Sans TC→Noto Sans CJK SC（简繁全覆盖；两者均 OFL 可商用，字体文件随 brand-assets/fonts/ 分发）。Noto Sans SC 为 Google Fonts 上的网络字体名（web 端回退）；mono 沿用智控王。",
      "sans": ["Montserrat", "Noto Sans CJK SC", "Noto Sans SC", "PingFang SC", "Microsoft YaHei", "system-ui", "-apple-system", "sans-serif"],
      "mono": ["JetBrains Mono", "Fira Code", "Consolas", "monospace"]
    },
    "fontSize": {
      "_note": "字号阶，沿用智控王（xs 12px … 5xl 48px）。",
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem"
    },
    "fontWeight": {
      "_note": "black=900 为品牌标题字重（brand-assets 排版用 Noto Black / Montserrat 900），其余沿用智控王。",
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700",
      "black": "900"
    },
    "lineHeight": {
      "none": "1",
      "tight": "1.25",
      "snug": "1.375",
      "normal": "1.5",
      "relaxed": "1.625",
      "loose": "2"
    },
    "letterSpacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0em",
      "wide": "0.025em",
      "wider": "0.05em"
    }
  },

  "motion": {
    "_note": "动效令牌，沿用智控王 animation.duration/easing；easing 键名即 Tailwind ease-* 后缀（原 easeIn/easeOut/easeInOut → in/out/in-out）。keyframes 属组件层实现细节，留在各端组件库，不入品牌令牌。",
    "duration": {
      "fast": "150ms",
      "normal": "200ms",
      "slow": "300ms",
      "slower": "500ms"
    },
    "easing": {
      "linear": "linear",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "in-out": "cubic-bezier(0.4, 0, 0.2, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "bounce": "cubic-bezier(0.68, -0.55, 0.265, 1.55)"
    }
  },

  "zIndex": {
    "_note": "层级表，沿用智控王（skipLink 更名 skip-link 以统一 kebab-case）。",
    "hide": -1,
    "auto": "auto",
    "base": 0,
    "docked": 10,
    "dropdown": 1000,
    "sticky": 1100,
    "banner": 1200,
    "overlay": 1300,
    "modal": 1400,
    "popover": 1500,
    "skip-link": 1600,
    "toast": 1700,
    "tooltip": 1800
  },

  "breakpoints": {
    "_note": "断点，沿用智控王（与 Tailwind 默认一致）。",
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },

  "themes": {
    "_note": "表层语义映射，驱动 brand.css 的 :root（light）与 [data-theme=dark]。冲突消解：dark 背景改用 brand.ink 深空阶（不再用 slate）；light 正文用品牌墨色 #0b1020（原 gray-900）。border.focus 走智连蓝（dark 用 400 提亮）。",
    "light": {
      "background": {
        "primary": "#ffffff",
        "secondary": "#f9fafb",
        "tertiary": "#f3f4f6"
      },
      "text": {
        "primary": "#0b1020",
        "secondary": "#4b5563",
        "tertiary": "#9ca3af",
        "inverse": "#ffffff"
      },
      "border": {
        "default": "#e5e7eb",
        "focus": "#1e8cf2"
      }
    },
    "dark": {
      "background": {
        "primary": "#05060f",
        "secondary": "#0a0c1b",
        "tertiary": "#11132a"
      },
      "text": {
        "primary": "#f9fafb",
        "secondary": "#d1d5db",
        "tertiary": "#6b7280",
        "inverse": "#0b1020"
      },
      "border": {
        "default": "#1a1d3a",
        "focus": "#54a7f5"
      }
    }
  }
}
