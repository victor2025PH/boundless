# boundless 全域 .gitattributes
# 大二进制走 git-LFS（对未来新增文件生效；已在库的字体由 tools/prepush_cleanup.ps1 一次性迁移）。
brand-assets/fonts/*.otf  filter=lfs diff=lfs merge=lfs -text
brand-assets/fonts/*.ttf  filter=lfs diff=lfs merge=lfs -text
*.psd   filter=lfs diff=lfs merge=lfs -text
*.sketch filter=lfs diff=lfs merge=lfs -text
*.mp4   filter=lfs diff=lfs merge=lfs -text
*.mov   filter=lfs diff=lfs merge=lfs -text

# 统一换行：脚本保持 LF/CRLF 原样，避免跨平台噪声
*.sh   text eol=lf
*.ps1  text eol=crlf
*.bat  text eol=crlf
brand-assets/fonts/*.otf filter=lfs diff=lfs merge=lfs -text
brand-assets/fonts/*.ttf filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.psd filter=lfs diff=lfs merge=lfs -text
