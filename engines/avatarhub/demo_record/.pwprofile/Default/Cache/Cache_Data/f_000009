  if(!list||!list.length){ bar.style.display='none'; return; }
  bar.className='conflictbar'+(list.some(i=>i.level==='red')?'':' yellow');
  bar.innerHTML=list.map(i=>`${i.level==='red'?'🔴':'🟡'} ${esc(i.msg)} <b style="opacity:.9">→ ${esc(i.fix)}</b>`).join('<br>');
  bar.style.display='';
}
