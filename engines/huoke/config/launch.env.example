# OpenClaw launch profile (模板) — 复制为 config/launch.env 后按需修改
#   cp config/launch.env.example config/launch.env
# 由 start.bat / migrate.bat（scripts/ops/start.ps1）加载进程环境后启动 server。
# 这是本机服务端口/绑定/TLS/API Key 的【单一权威来源】(single source of truth)。
# 改动后需 stop.bat 再 start.bat 生效。文档见 docs/SYSTEM_RUNBOOK.md §0。

# --- 监听端口 (默认 18080，来自 src/openclaw_env.py) ---
# 后台地址: http://localhost:<PORT>/dashboard
OPENCLAW_PORT=18080

# --- 绑定地址 (默认 0.0.0.0 = 局域网可达) ---
# 只想本机访问时设为 127.0.0.1 (RUNBOOK F1)
# OPENCLAW_HOST=0.0.0.0

# --- TLS (默认关) ---
# 设为 1 启用 HTTPS，使用 config/certs/server.{key,crt}
# OPENCLAW_TLS=0

# --- API Key (默认关；生产建议开启，见 RUNBOOK §3) ---
# 为空 = 后台/接口不鉴权(裸奔)。生产务必设强随机值，并与所有 worker 保持一致。
# OPENCLAW_API_KEY=

# --- 关闭设备健康监控 (调试用) ---
# OPENCLAW_DISABLE_DEVICE_HEALTH_MONITOR=0
